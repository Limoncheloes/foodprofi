# Database
POSTGRES_DB=supplyflow
POSTGRES_USER=supplyflow
POSTGRES_PASSWORD=supplyflow_secret
DATABASE_URL=postgresql+asyncpg://supplyflow:supplyflow_secret@postgres:5432/supplyflow

# Auth
SECRET_KEY=change_me_in_production_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=supplyflow

# App
BACKEND_CORS_ORIGINS=http://localhost:3000
